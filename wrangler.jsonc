{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "mem-benchmark-vis",
  "main": "worker/index.js",
  "compatibility_date": "2025-03-01",
  "routes": [
    {
      "pattern": "mem.102465.xyz",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  }
}
